# Telegram API Credentials (from https://my.telegram.org/apps)
TELEGRAM_API_ID=123456789
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# Your Telegram phone number (with country code)
TELEGRAM_PHONE=+1234567890

# Channel to monitor (can be @username or channel_id)
# Example: @mychannel or 123456789
MONITOR_CHANNEL=@mychannel

# ntfy.sh configuration
# Choose a unique topic name (this becomes the URL)
# You'll receive alerts at: https://ntfy.sh/NTFY_TOPIC
NTFY_TOPIC=my_telegram_alerts_12345xyz

# (Optional) Increase to see more detailed logs
LOG_LEVEL=INFO
